{
  "name": "eorg",
  "version": "1.5.0",
  "private": true,
  "type": "module",
  "description": "Mailita Chrome extension and backend",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "typecheck": "tsc --noEmit",
    "test:headless": "bash tests/headless/run_all.sh",
    "test:contracts": "node tests/contracts/verify_runtime_contracts.mjs && node --test tests/contracts/guide-state-migration.test.mjs && node --test tests/manifest-runtime.test.mjs && node --test apps/backend/lib/errors.test.js apps/backend/lib/message-identity.test.js apps/backend/lib/message-normalize.test.js",
    "test:triage": ".venv/bin/python3 tests/headless/run_triage_harness.py",
    "test:chat": ".venv/bin/python3 tests/headless/run_chat_harness.py",
    "test:compose": ".venv/bin/python3 tests/headless/run_compose_harness.py",
    "test:reply": ".venv/bin/python3 tests/headless/run_reply_harness.py"
  },
  "devDependencies": {
    "@inboxsdk/core": "2.2.11",
    "@types/chrome": "latest",
    "playwright": "latest",
    "typescript": "latest",
    "wxt": "latest"
  }
}
