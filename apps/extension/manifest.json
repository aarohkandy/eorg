{
  "manifest_version": 3,
  "name": "Gmail Unified",
  "description": "Full-screen Gmail replacement with backend Inbox + Sent sync.",
  "version": "1.2.21",
  "permissions": ["storage", "unlimitedStorage", "tabs"],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://email-bcknd.onrender.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": [
        "content/gmail-inject-foundation.js",
        "content/gmail-inject-render.js",
        "content/gmail-inject-mailbox.js",
        "content/gmail-inject-setup.js",
        "content/gmail-inject-sidebar.js",
        "content/gmail-inject-main.js",
        "content/gmail-inject.js"
      ],
      "css": ["content/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  }
}
