{
  "manifest_version": 3,
  "name": "Gmail Unified",
  "description": "Full-screen Gmail replacement with backend Inbox + Sent sync.",
  "version": "1.2.20",
  "permissions": ["storage", "unlimitedStorage", "scripting", "tabs"],
  "host_permissions": [
    "*://mail.google.com/*",
    "https://myaccount.google.com/*",
    "https://email-bcknd.onrender.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*", "https://myaccount.google.com/*"],
      "js": ["content/gmail-inject.js"],
      "css": ["content/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "styles.css",
        "styles-shell.css",
        "styles-thread.css",
        "page-debug-bridge.js",
        "pageWorld.js"
      ],
      "matches": ["*://mail.google.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  }
}
