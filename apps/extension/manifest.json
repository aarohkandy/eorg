{
  "manifest_version": 3,
  "name": "Mailita",
  "description": "Chat-style Gmail replacement powered by a Mailita backend.",
  "version": "1.5.0",
  "permissions": ["storage", "unlimitedStorage", "tabs", "alarms"],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://email-bcknd.onrender.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content/gmail-inject.js"],
      "css": ["content/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  }
}
