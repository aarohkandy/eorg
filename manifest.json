{
  "manifest_version": 3,
  "name": "Mailita",
  "description": "Chat-style Gmail replacement powered by direct Gmail OAuth.",
  "version": "1.5.0",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "tabs",
    "alarms",
    "identity"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://www.googleapis.com/*",
    "http://localhost:7676/*"
  ],
  "oauth2": {
    "client_id": "164613854790-smorr6t61h9k1cgvo6msjjtpk8b82p3h.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.readonly"
    ]
  },
  "background": {
    "service_worker": "apps/extension/background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "apps/extension/content/gmail-inject.js"
      ],
      "css": [
        "apps/extension/content/styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "apps/extension/popup/popup.html"
  }
}
