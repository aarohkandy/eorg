{
  "manifest_version": 3,
  "name": "Gmail Unified",
  "description": "Full-screen Gmail replacement with backend Inbox + Sent sync.",
  "version": "1.2.21",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "tabs"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://email-bcknd.onrender.com/*"
  ],
  "background": {
    "service_worker": "apps/extension/background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "apps/extension/content/gmail-inject.js"
      ],
      "css": [
        "apps/extension/content/styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "apps/extension/popup/popup.html"
  }
}
